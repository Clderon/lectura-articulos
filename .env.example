# ============================================================
# CONFIGURACIÓN LECTURA SELECTIVA - Local Pipeline
# ============================================================

# 1. DEEPSEEK API (Requerido)
# ============================================================
# Obtén tu key gratis en: https://platform.deepseek.com/
# Formato: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. RUTAS DEL SISTEMA (Requerido)
# ============================================================
# IMPORTANTE en Windows: Usa barras diagonales / o dobles \\

# Carpeta con PDFs a procesar (debe existir)
# Ejemplo: C:\Users\usuario\Downloads\Articulos
PDF_FOLDER=C:/Proyectos/Lectura-Selectiva/pdfs

# Archivo Excel con 2 hojas: "Revisión de Artículos" y "Lectura Selectiva"
# El encabezado debe estar en fila 3
# Ejemplo: C:\Users\usuario\Desktop\Revisión de Artículos - V3.xlsx
EXCEL_PATH=C:/Users/usuario/Desktop/Revision_de_Articulos.xlsx

# 3. NOMBRES DE HOJAS EN EXCEL (Ajusta si tus hojas se llaman diferente)
# ============================================================
SHEET1_NAME=Revisión de Artículos
SHEET2_NAME=Lectura Selectiva

# 4. CONFIGURACIÓN AVANZADA (Opcional - no cambiar si no sabes)
# ============================================================
MODO_VERIFICACION=0
MAX_WORDS_PER_CHUNK=6000
TEST_MINERU=0
